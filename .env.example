# Move & Meditate — environment variables
#
# Copy this file to `.env.local` for local dev (auto-gitignored), and set the
# same keys in Vercel → Project Settings → Environment Variables for prod.

# --- Contact form (Google Apps Script Web App) ---
# The deployed Web App URL. Looks like https://script.google.com/macros/s/.../exec
CONTACT_WEBHOOK_URL=

# Must match SHARED_SECRET set inside the Apps Script. Long random string.
CONTACT_WEBHOOK_SECRET=

# --- Sanity CMS ---
# Project ID + dataset are public (browser-exposed via NEXT_PUBLIC_*).
# Find these at https://www.sanity.io/manage → your project.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-12-01

# Viewer-scoped read token (server-only). Generated in Sanity manage UI
# → API → Tokens. Required for reading drafts in preview mode and for
# build-time fetches that need to bypass the public CDN.
SANITY_API_READ_TOKEN=

# Long random string used by /api/revalidate webhook to authenticate
# Sanity → Next.js cache-invalidation requests. Configure the same value
# in the Sanity webhook payload secret.
SANITY_REVALIDATE_SECRET=
